# =============================================================================
# Ollama server settings
# Start with: OLLAMA_MAX_LOADED_MODELS=3 OLLAMA_NUM_PARALLEL=4 ollama serve
# Default port: 11434 | Cluster port: 11436
# =============================================================================

# ---------------------------------------------------------------------------
# Vision Agent — processes image → general_description + crop_descriptions
# ---------------------------------------------------------------------------
VISION_MODEL=qwen3-vl:32b
VISION_OLLAMA_HOST=http://localhost:11434
VISION_NUM_CTX=8192
VISION_THINK=false

# ---------------------------------------------------------------------------
# Orchestrator Agent — /no_think (prompt formatting only)
# ---------------------------------------------------------------------------
ORCHESTRATOR_MODEL=qwen3:32b
ORCHESTRATOR_OLLAMA_HOST=http://localhost:11434
ORCHESTRATOR_NUM_CTX=4096
ORCHESTRATOR_THINK=false

# ---------------------------------------------------------------------------
# Linguistic Agent — /no_think (language detection)
# ---------------------------------------------------------------------------
LINGUISTIC_MODEL=qwen3:32b
LINGUISTIC_OLLAMA_HOST=http://localhost:11434
LINGUISTIC_NUM_CTX=4096
LINGUISTIC_THINK=false          # both tool + run calls
# LINGUISTIC_THINK_TOOL=false   # override for tool call only
# LINGUISTIC_THINK_RUN=false    # override for run call only

# ---------------------------------------------------------------------------
# Landscape Agent — /no_think (landscape classification)
# ---------------------------------------------------------------------------
LANDSCAPE_MODEL=qwen3:32b
LANDSCAPE_OLLAMA_HOST=http://localhost:11434
LANDSCAPE_NUM_CTX=4096
LANDSCAPE_THINK=false

# ---------------------------------------------------------------------------
# Meta Agent — /no_think for RAG lookup, /think for reasoning
# ---------------------------------------------------------------------------
META_MODEL=qwen3:32b
META_OLLAMA_HOST=http://localhost:11434
META_NUM_CTX=8192
META_THINK_RUN=false            # tool dispatch — no thinking needed
META_THINK_REASON=true          # country reasoning — thinking enabled

# ---------------------------------------------------------------------------
# Judge Agent — /no_think for tool dispatch, /think for identify_country
# ---------------------------------------------------------------------------
JUDGE_MODEL=qwen3:32b
JUDGE_OLLAMA_HOST=http://localhost:11434
JUDGE_NUM_CTX=8192
JUDGE_THINK_RUN=false           # tool dispatch — no thinking needed
JUDGE_THINK_TOOL=true           # identify_country — thinking enabled

# ---------------------------------------------------------------------------
# Embedding (geoguessr_rag) — must match the model used to build the DB
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=qwen3-embedding:8b
OLLAMA_HOST=http://localhost:11436
EMBEDDING_DIMENSIONS=4096

# For local dev with a smaller embedding model (re-index required):
# EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_HOST=http://localhost:11434
# EMBEDDING_DIMENSIONS=768
