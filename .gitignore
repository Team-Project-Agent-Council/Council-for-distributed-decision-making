/out/
/.next/

# ---- Python ----------------------------------------------------------------
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.pytest.ini
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.ipynb_checkpoints/
build/
dist/

# ---- Node / Next.js --------------------------------------------------------
node_modules/
/node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.turbo/
.vercel
*.tsbuildinfo
next-env.d.ts
/coverage
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- Secrets ---------------------------------------------------------------
.env
.env*
.env.local
.env.*.local
.env.production
*.pem
*.key
*.p12

